# =============================================================
# BETA-ОКРУЖЕНИЕ «ДО ВСТРЕЧИ»
# Скопируй как .env.beta на VPS и заполни реальными значениями
# НИКОГДА не коммить .env.beta с реальными данными!
# =============================================================

# === Telegram Bot (ОТДЕЛЬНЫЙ от прода!) ===
# Создай через @BotFather: /newbot → бета-бот
# Затем /setdomain → beta.dovstrechiapp.ru
BOT_TOKEN=your-beta-bot-token-from-botfather

# === Database (отдельная от прода!) ===
POSTGRES_DB=dovstrechi_beta
POSTGRES_USER=dovstrechi
# ВНИМАНИЕ: не используй @ ! # $ в пароле — они ломают DATABASE_URL
# Генерация: python3 -c "import secrets,string; c=string.ascii_letters+string.digits; print(''.join(secrets.choice(c) for _ in range(32)))"
POSTGRES_PASSWORD=your-beta-secure-password-here

# === Backend ===
# Генерация: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=generate-beta-secret-key

# Внутренний ключ бот↔backend
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=generate-beta-internal-key

# URL beta Mini App (без / на конце)
MINI_APP_URL=https://beta.dovstrechiapp.ru

# CORS — только beta домен
ALLOWED_ORIGINS=https://beta.dovstrechiapp.ru

# === Admin Panel ===
# Тот же Telegram ID что и в проде
ADMIN_TELEGRAM_ID=your-telegram-id

# Время жизни сессии в часах
ADMIN_SESSION_TTL_HOURS=2

# IP-allowlist (оставить пустым для отключения)
ADMIN_IP_ALLOWLIST=

# Соль для анонимизации (отдельная от прода)
# Генерация: python3 -c "import secrets; print(secrets.token_hex(16))"
ANONYMIZE_SALT=generate-beta-random-string

# === Пути (не менять если стандартная установка) ===
BETA_DIR=/opt/dovstrechi-beta
