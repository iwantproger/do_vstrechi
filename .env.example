# =============================================================
# КОНФИГУРАЦИЯ «ДО ВСТРЕЧИ»
# Скопируй этот файл как .env и заполни реальными значениями
# НИКОГДА не коммить .env с реальными данными!
# =============================================================

# === Telegram Bot ===
# Получи токен у @BotFather через /newbot или /token
BOT_TOKEN=your-bot-token-from-botfather

# === Database ===
POSTGRES_DB=dovstrechi
POSTGRES_USER=dovstrechi
# ВНИМАНИЕ: не используй @ ! # $ в пароле — они ломают DATABASE_URL
# Генерация: python3 -c "import secrets,string; c=string.ascii_letters+string.digits; print(''.join(secrets.choice(c) for _ in range(32)))"
POSTGRES_PASSWORD=your-secure-password-here

# Собирается автоматически в docker-compose. Задай явно если пароль содержит спецсимволы:
# DATABASE_URL=postgresql://dovstrechi:your-password@postgres:5432/dovstrechi

# === Backend ===
# Генерация: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=generate-with-openssl-rand-hex-32

# Внутренний ключ для аутентификации бот↔backend
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=generate-with-openssl-rand-hex-32

# URL задеплоенного Mini App (без / на конце)
MINI_APP_URL=https://dovstrechiapp.ru

# Внутренние URL сервисов (значения по умолчанию подходят для docker-compose)
BOT_INTERNAL_URL=http://bot:8080
BACKEND_API_URL=http://backend:8000

# === Admin Panel ===
# Telegram ID владельца (найти через @userinfobot)
ADMIN_TELEGRAM_ID=your-telegram-id

# Время жизни сессии в часах
ADMIN_SESSION_TTL_HOURS=2

# IP-allowlist для доступа к админке (через запятую, оставить пустым для отключения)
ADMIN_IP_ALLOWLIST=

# Соль для анонимизации Telegram ID в аналитике
# ОБЯЗАТЕЛЬНАЯ переменная — без неё backend упадёт при старте (KeyError).
# Должна быть случайной и иметь минимум 16 символов (проверяется assert'ом).
# Генерация: python3 -c "import secrets; print(secrets.token_hex(16))"
# НИКОГДА не используй предсказуемые значения — это позволит восстановить
# telegram_id из anonymous_id через rainbow tables.
ANONYMIZE_SALT=generate-random-string-here-at-least-16-chars

# === Календарная интеграция ===
# Ключ шифрования токенов (Fernet)
# Генерация: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Google Calendar OAuth (console.cloud.google.com → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://dovstrechiapp.ru/api/calendar/google/callback

# === Phase 2: OAuth redirect + Webhooks ===
# Имя бота без @ — для OAuth callback auto-redirect страницы
BOT_USERNAME=do_vstrechi_bot
# HTTPS URL для Google Calendar push-уведомлений (webhook)
CALENDAR_WEBHOOK_URL=https://dovstrechiapp.ru/api/calendar/webhook/google

# === Bot Webhook ===
# Telegram шлёт обновления на наш URL вместо polling
WEBHOOK_ENABLED=true
WEBHOOK_HOST=https://dovstrechiapp.ru
WEBHOOK_PATH=/bot/webhook
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=generate-webhook-secret-hex
