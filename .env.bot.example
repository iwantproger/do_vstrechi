# =============================================================
# КОНФИГУРАЦИЯ ДЛЯ БОТА НА ОТДЕЛЬНОМ VPS (foreign)
# Используется с docker-compose.bot.yml
# Скопируй как .env (на финском VPS), заполни реальными значениями.
# НИКОГДА не коммить .env с реальными данными!
# =============================================================

# === Telegram ===
# Тот же токен, что использовался на основном сервере (от @BotFather)
BOT_TOKEN=your-bot-token-from-botfather
BOT_USERNAME=do_vstrechi_bot

# === Network binding (WireGuard) ===
# Если бот запущен на foreign VPS с WG-туннелем к backend:
# BOT_BIND_HOST=10.0.0.2  ← внутренний IP WG-интерфейса; бот не доступен публично
# Без этой переменной (локальная разработка) — бот слушает на 0.0.0.0:8080
# BOT_BIND_HOST=10.0.0.2

# === Backend (на Timeweb, обращаемся через публичный nginx) ===
# Бот ходит на бэкенд через HTTPS, проходя нашим обычным nginx-proxy.
BACKEND_API_URL=https://dovstrechiapp.ru

# Mini App URL — тот же что и backend.
MINI_APP_URL=https://dovstrechiapp.ru

# Тот же INTERNAL_API_KEY, что в .env на Timeweb.
# Используется для подписи Bot↔Backend внутренних запросов через X-Internal-Key.
INTERNAL_API_KEY=must-match-timeweb-internal-api-key

# === Admins ===
# Те же ID, что и на Timeweb (через запятую, первый = owner).
ADMIN_TELEGRAM_IDS=your-telegram-id
# Fallback, если ADMIN_TELEGRAM_IDS не задан:
ADMIN_TELEGRAM_ID=0
